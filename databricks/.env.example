# NOTE: dbt Fusion is installed separately — see README.md and
# FUSION_VERSION.txt. It is not configured via this .env file.

# ── Databricks ─────────────────────────────────────────────
DATABRICKS_HOST=https://community.cloud.databricks.com
DATABRICKS_TOKEN=dapiXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
DATABRICKS_HTTP_PATH=/sql/1.0/warehouses/XXXXXXXXXXXXXXXX
DATABRICKS_CLUSTER_ID=XXXX-XXXXXX-XXXXXXXX

# ── AI Agent ───────────────────────────────────────────────
GEMINI_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXX

# ── n8n alerting (optional) ────────────────────────────────
N8N_WEBHOOK_URL=http://localhost:5678/webhook/tlc-pipeline-alert
ALERT_EMAIL=your.email@gmail.com
