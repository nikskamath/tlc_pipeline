# NOTE: dbt Fusion is installed separately — see README.md and
# FUSION_VERSION.txt. It is not configured via this .env file.

# ── Snowflake ──────────────────────────────────────────────
SF_ACCOUNT=myorg-myaccount
SF_USER=your_username
SF_PASSWORD=your_password

# ── AI Agent ───────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key
GEMINI_API_URL=https://api.generativelanguage.googleapis.com/v1beta2/models/gemini-1.5-mini:predict

# ── n8n alerting (optional) ────────────────────────────────
N8N_WEBHOOK_URL=http://localhost:5678/webhook/tlc-pipeline-alert
ALERT_EMAIL=your.email@gmail.com
